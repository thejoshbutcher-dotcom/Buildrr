# Netlify OAuth app credentials for one-click Publish.
# Create an OAuth app at: https://app.netlify.com/user/applications  → "New OAuth app"
# Set its redirect URI to match NETLIFY_REDIRECT_URI below.
#
# Then copy this file to `.env` (same folder) and fill in the values.
# The server auto-loads .env on start; restart it after editing.

NETLIFY_CLIENT_ID=
NETLIFY_CLIENT_SECRET=
# Must EXACTLY match the "Redirect URI" set on the Netlify OAuth app.
# Local dev:  http://localhost:8787/api/netlify/callback
# Production: https://buildrr.io/api/netlify/callback
NETLIFY_REDIRECT_URI=http://localhost:8787/api/netlify/callback

# Optional
# PORT=8787
# NODE_ENV=production
