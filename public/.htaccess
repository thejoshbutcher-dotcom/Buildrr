# Buildrr — single-page app fallback + static asset caching (Apache / Hostinger)
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /
  # Serve real files/directories as-is (assets, images, etc.)
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]
  # Everything else -> index.html so the React router handles /app etc.
  RewriteRule ^ index.html [L]
</IfModule>

# Cache the fingerprinted assets hard; keep index.html fresh
<IfModule mod_headers.c>
  <FilesMatch "\.(js|css|woff2?|png|jpg|jpeg|svg|gif|ico)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  <FilesMatch "index\.html$">
    Header set Cache-Control "no-cache"
  </FilesMatch>
</IfModule>
